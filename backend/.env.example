# Server
PORT=3001
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Supabase persistence
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated

# Chat runtime rollout flags
CHAT_RUNTIME_ENABLED=true
CONVERSATION_LOOP_ENABLED=true
GENERATE_EXPERIENCE_TOOL_ENABLED=true
ROUTER_STAGE_ENABLED=true

# Conversation model config
CONVERSATION_PROVIDER=openai
CONVERSATION_MODEL=gpt-5.4
CONVERSATION_MAX_TOKENS=4096
CONVERSATION_MAX_TOOL_ROUNDS=4
CONVERSATION_SYSTEM_PROMPT=

# Router model config (optional overrides)
LLM_ROUTER_PROVIDER=openai
LLM_ROUTER_MODEL=gpt-5-mini
LLM_ROUTER_MAX_TOKENS=1024

# Generation output token budgets (optional overrides)
LLM_MAX_TOKENS_DEFAULT=32768
LLM_MAX_TOKENS_RETRY=32768

# Billing foundation (defaults off; backend reads flags only until Stripe/grants ship)
BILLING_ENABLED=false
CREDIT_ENFORCEMENT_ENABLED=false
STRIPE_WEBHOOKS_ENABLED=false
BILLING_PORTAL_ENABLED=false
FREE_CREDIT_GRANTS_ENABLED=false
TOPUPS_ENABLED=false

# Optional numeric overrides for launch catalog (defaults match seeded pricing_rule_snapshots.launch-v1)
# BILLING_FREE_MONTHLY_CREDITS=15
# BILLING_PAID_MONTHLY_CREDITS=150
# BILLING_FAST_CREDITS=1
# BILLING_QUALITY_CREDITS=5
# BILLING_TOPUP_CREDITS=50
# BILLING_TOPUP_PRICE_USD=4
# BILLING_PAID_PLAN_PRICE_USD=10

# Stripe (leave empty until integration change)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PAID_MONTHLY=
STRIPE_PRICE_ID_TOPUP_50=
